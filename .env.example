# ─── TraceLens AI Engine Configuration ──────────────────────────────────────────
#
# Copy this file to .env and fill in your chosen provider's API key.
# TraceLens uses BYOK (Bring Your Own Key) — keys are never hardcoded.
#
# PROVIDER OPTIONS:
#   openai      → requires OPENAI_API_KEY
#   gemini      → requires GEMINI_API_KEY      (recommended: free tier available)
#   anthropic   → requires ANTHROPIC_API_KEY
#   openrouter  → requires OPENROUTER_API_KEY  (access 200+ models, pay-per-use)
#
# MODEL EXAMPLES:
#   openai:     gpt-4o-mini, gpt-4o, o3-mini
#   gemini:     gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-pro
#   anthropic:  claude-3-haiku-20240307, claude-3-5-sonnet-20241022
#   openrouter: openai/gpt-4o-mini, google/gemini-2.5-flash
#
# QUICK START (recommended — Gemini has a generous free tier):
#   1. Get a free API key at: https://aistudio.google.com/apikey
#   2. Set TRACELENS_AI_PROVIDER=gemini
#   3. Set TRACELENS_AI_MODEL=gemini-2.5-flash
#   4. Set GEMINI_API_KEY=your-key-here
# ─────────────────────────────────────────────────────────────────────────────────

TRACELENS_AI_PROVIDER=gemini
TRACELENS_AI_MODEL=gemini-2.5-flash

# ─── Test Target URL ─────────────────────────────────────────────────────────────
#
# URL used by all test-*.ts scripts (test-pipeline, test-lighthouse, etc.)
# Change this ONE value to point every test at your target.
#
# Examples:
#   Local dev server : http://localhost:3000
#   Specific route   : http://localhost:3000/dashboard
#   Live site        : https://yourapp.com
#   Public test site : https://www.cnn.com
#
TRACELENS_TEST_URL=http://localhost:3000

# Fill in the key for your chosen provider:
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
