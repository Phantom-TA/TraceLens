{
  "name": "@tracelens/cli",
  "version": "2.0.0",
  "description": "TraceLens AI-Powered Frontend Performance Intelligence CLI",
  "type": "module",
  "bin": {
    "tracelens": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
