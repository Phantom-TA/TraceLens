{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": [
    "test-*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages",
    "cli",
    "dist-test",
    "dist-test-bundle",
    "dist-test-parser",
    "dist-test-pipeline"
  ]
}