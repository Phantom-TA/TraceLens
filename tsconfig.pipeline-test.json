{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "test-pipeline.ts",
    "packages/report-engine/src/**/*.ts",
    "packages/playwright-runner/src/**/*.ts",
    "packages/lighthouse-runner/src/**/*.ts",
    "packages/trace-parser/src/**/*.ts",
    "packages/bundle-analyzer/src/**/*.ts"
  ]
}
