{
  "name": "@tracelens/playwright-runner",
  "version": "0.1.0",
  "description": "Production-grade Playwright browser runner for TraceLens — captures screenshots, traces, and HAR artifacts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "playwright": "^1.43.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
